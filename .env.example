# --- Flask Configuration ---
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=generate-a-secure-random-key-here

# --- Database Configuration ---
# Default to SQLite for local development
DATABASE_URL=sqlite:///e16.db
# For Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/e16_db

# --- Email Configuration (SMTP) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# --- Google OAuth Configuration ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Security ---
# Seed key for initial database initialization
SEED_KEY=e16-secret-seed-key-2024

# --- Storage Backend ---
# "local" (mặc định, lưu vào static/uploads) hoặc "s3"
STORAGE_BACKEND=local

# Chỉ cần điền nếu STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=e16-lms-uploads
# AWS_S3_REGION=ap-southeast-1
